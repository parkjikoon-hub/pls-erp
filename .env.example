# ERP 환경 변수 설정 파일
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# cp .env.example .env

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://erp_user:your_password@localhost:5432/erp_db
# PostgreSQL 설치 후 아래 명령어로 DB 생성:
# createdb erp_db
# createuser erp_user
# psql -c "ALTER USER erp_user PASSWORD 'your_password';"

# ─── AI Engine ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini API 키 발급: https://aistudio.google.com/apikey

# ─── Authentication ────────────────────────────────────────
JWT_SECRET_KEY=your_very_long_random_secret_key_here_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── 이카운트 OpenAPI ─────────────────────────────────────
ECOUNT_COMPANY_CODE=your_ecount_company_code
ECOUNT_API_KEY=your_ecount_api_key
# 이카운트 OpenAPI 설정: 이카운트 → 환경설정 → API 연동

# ─── 카카오 알림톡 ────────────────────────────────────────
KAKAO_API_KEY=your_kakao_rest_api_key
# 카카오 알림톡 키 발급: https://developers.kakao.com

# ─── Slack Webhook ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# Slack Webhook 설정: Slack → 앱 → Incoming Webhooks

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# Gmail 앱 비밀번호: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호

# ─── Banking API ──────────────────────────────────────────
# (실제 운영 시 은행별 API 키 입력)
BANK_API_KEY=your_bank_api_key
BANK_ACCOUNT_NO=your_company_account_number

# ─── App Settings ─────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Frontend URL (CORS 설정용)
FRONTEND_URL=http://localhost:3000
